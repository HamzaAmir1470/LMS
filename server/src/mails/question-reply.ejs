<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>New Reply Notification</title>
    <style>
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }
      body {
        font-family:
          -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica,
          Arial, sans-serif;
        background-color: #f4f7fb;
        line-height: 1.6;
        color: #1a2332;
        padding: 20px;
      }
      .email-wrapper {
        max-width: 600px;
        margin: 0 auto;
        background-color: #ffffff;
        border-radius: 16px;
        box-shadow: 0 8px 30px rgba(0, 0, 0, 0.06);
        overflow: hidden;
      }
      .email-header {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        padding: 32px 40px;
        text-align: center;
      }
      .logo {
        color: #ffffff;
        font-size: 28px;
        font-weight: 700;
        text-decoration: none;
      }
      .logo span {
        font-weight: 300;
      }
      .email-body {
        padding: 40px;
      }
      .greeting {
        font-size: 22px;
        font-weight: 600;
        margin-bottom: 6px;
      }
      .greeting-highlight {
        color: #667eea;
      }
      .notification-box {
        background: #f8faff;
        border-radius: 12px;
        padding: 24px;
        margin: 20px 0;
        border: 1px solid #e8edf5;
      }
      .video-title {
        font-size: 18px;
        font-weight: 600;
        color: #1a2332;
        margin-top: 5px;
      }
      .reply-preview {
        background: #ffffff;
        border-radius: 8px;
        padding: 16px;
        margin-top: 16px;
        border-left: 4px solid #f093fb;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.04);
      }
      .reply-preview .content {
        font-style: italic;
        color: #4a5568;
      }
      .cta-container {
        text-align: center;
        margin: 30px 0;
      }
      .btn-primary {
        display: inline-block;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: #ffffff !important;
        text-decoration: none;
        padding: 14px 40px;
        border-radius: 50px;
        font-weight: 600;
      }
      .footer {
        padding: 0 40px 32px;
        text-align: center;
        font-size: 13px;
        color: #6b7a8f;
      }
    </style>
  </head>
  <body>
    <div class="email-wrapper">
      <div class="email-header">
        <a href="#" class="logo">Dev<span>Learn</span></a>
      </div>

      <div class="email-body">
        <h1 class="greeting">
          Hello <span class="greeting-highlight"><%= name %></span> 👋
        </h1>
        <p>A new admin reply has been added to your question.</p>

        <div class="notification-box">
          <strong
            style="color: #667eea; font-size: 12px; text-transform: uppercase"
            >Course Content</strong
          >
          <div class="video-title">"<%= title %>"</div>

          <div class="reply-preview">
            <span
              style="
                font-size: 12px;
                font-weight: 600;
                color: #6b7a8f;
                display: block;
                margin-bottom: 4px;
              "
              >ADMIN RESPONSE:</span
            >
            <div class="content">"<%= replyPreview %>"</div>
          </div>
        </div>

        <p>
          Please log in to your dashboard to view the full discussion thread and
          reply back if needed.
        </p>

        <div class="cta-container">
          <a href="<%= actionLink %>" class="btn-primary"
            >View Reply On Platform →</a
          >
        </div>
      </div>

      <div class="footer">
        <p><strong>DevLearn</strong> — Empowering learners worldwide</p>
      </div>
    </div>
  </body>
</html>
