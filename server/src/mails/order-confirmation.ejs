<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <title>Order Confirmation</title>
    <style>
        /* Reset styles for email clients */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
            background-color: #f4f7fb;
            line-height: 1.6;
            color: #1a2332;
            padding: 20px;
        }
        
        .email-wrapper {
            max-width: 650px;
            margin: 0 auto;
            background-color: #ffffff;
            border-radius: 16px;
            box-shadow: 0 8px 30px rgba(0, 0, 0, 0.06);
            overflow: hidden;
        }
        
        /* Header */
        .email-header {
            background: linear-gradient(135deg, #2d3748 0%, #1a202c 100%);
            padding: 32px 40px;
            text-align: center;
            position: relative;
        }
        
        .email-header::after {
            content: '';
            position: absolute;
            bottom: 0;
            left: 0;
            right: 0;
            height: 4px;
            background: linear-gradient(90deg, #48bb78 0%, #38a169 100%);
        }
        
        .logo {
            display: inline-block;
            color: #ffffff;
            font-size: 28px;
            font-weight: 700;
            letter-spacing: -0.5px;
            text-decoration: none;
        }
        
        .logo-icon {
            display: inline-block;
            background: rgba(255, 255, 255, 0.15);
            padding: 8px 12px;
            border-radius: 12px;
            margin-right: 8px;
        }
        
        .logo span {
            font-weight: 300;
        }
        
        .order-status {
            display: inline-block;
            background: #48bb78;
            color: #ffffff;
            font-size: 11px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 1.2px;
            padding: 6px 18px;
            border-radius: 20px;
            margin-top: 10px;
        }
        
        .order-status.pending {
            background: #ed8936;
        }
        
        .order-status.shipped {
            background: #4299e1;
        }
        
        /* Content */
        .email-body {
            padding: 35px 40px 25px;
        }
        
        .greeting {
            font-size: 22px;
            font-weight: 600;
            color: #1a2332;
            margin-bottom: 4px;
        }
        
        .greeting-highlight {
            color: #2d3748;
        }
        
        .order-summary {
            background: #f7fafc;
            border-radius: 12px;
            padding: 20px 24px;
            margin: 18px 0 24px;
            border: 1px solid #e2e8f0;
            display: flex;
            flex-wrap: wrap;
            justify-content: space-between;
            align-items: center;
        }
        
        .order-number {
            font-size: 14px;
            color: #4a5568;
        }
        
        .order-number strong {
            color: #1a2332;
            font-size: 16px;
            font-weight: 700;
        }
        
        .order-date {
            font-size: 14px;
            color: #718096;
        }
        
        .order-total {
            font-size: 18px;
            font-weight: 700;
            color: #2d3748;
        }
        
        .order-total .currency {
            font-size: 14px;
            color: #718096;
            font-weight: 400;
        }
        
        /* Items Table */
        .items-table {
            width: 100%;
            border-collapse: collapse;
            margin: 20px 0 24px;
            font-size: 15px;
        }
        
        .items-table thead th {
            text-align: left;
            padding: 12px 12px 12px 0;
            border-bottom: 2px solid #e2e8f0;
            color: #4a5568;
            font-size: 12px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }
        
        .items-table tbody td {
            padding: 16px 12px 16px 0;
            border-bottom: 1px solid #edf2f7;
            vertical-align: middle;
        }
        
        .items-table tbody tr:last-child td {
            border-bottom: none;
        }
        
        .product-info {
            display: flex;
            align-items: center;
            gap: 14px;
        }
        
        .product-image {
            width: 52px;
            height: 52px;
            border-radius: 8px;
            background: #edf2f7;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 24px;
            flex-shrink: 0;
        }
        
        .product-name {
            font-weight: 600;
            color: #1a2332;
        }
        
        .product-sku {
            font-size: 13px;
            color: #718096;
        }
        
        .item-price {
            color: #2d3748;
            font-weight: 500;
        }
        
        .item-quantity {
            text-align: center;
            color: #4a5568;
        }
        
        .item-total {
            font-weight: 600;
            color: #1a2332;
            text-align: right;
        }
        
        /* Order Totals */
        .totals-container {
            background: #f7fafc;
            border-radius: 12px;
            padding: 20px 24px;
            margin: 20px 0 24px;
        }
        
        .totals-row {
            display: flex;
            justify-content: space-between;
            padding: 6px 0;
            font-size: 15px;
            color: #4a5568;
        }
        
        .totals-row.subtotal {
            border-bottom: 1px solid #e2e8f0;
            padding-bottom: 10px;
            margin-bottom: 6px;
        }
        
        .totals-row.discount {
            color: #e53e3e;
        }
        
        .totals-row.shipping {
            border-bottom: 1px solid #e2e8f0;
            padding-bottom: 10px;
            margin-bottom: 6px;
        }
        
        .totals-row.grand-total {
            font-size: 18px;
            font-weight: 700;
            color: #1a2332;
            padding-top: 8px;
        }
        
        .totals-row .label {
            font-weight: 500;
        }
        
        .totals-row .value {
            font-weight: 600;
        }
        
        .totals-row.grand-total .value {
            color: #2d3748;
        }
        
        /* Shipping & Payment */
        .details-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 20px;
            margin: 20px 0 24px;
        }
        
        .detail-box {
            background: #f7fafc;
            border-radius: 12px;
            padding: 16px 20px;
        }
        
        .detail-box h4 {
            font-size: 12px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            color: #718096;
            margin-bottom: 10px;
        }
        
        .detail-box p {
            font-size: 14px;
            color: #2d3748;
            line-height: 1.6;
        }
        
        .detail-box .address-line {
            display: block;
        }
        
        .detail-box .payment-method {
            display: flex;
            align-items: center;
            gap: 10px;
            margin-top: 4px;
        }
        
        .detail-box .payment-method .card-icon {
            font-size: 24px;
        }
        
        /* Message */
        .message-text {
            color: #2d3748;
            font-size: 15px;
            margin: 16px 0 8px;
            line-height: 1.7;
        }
        
        /* CTA */
        .cta-container {
            text-align: center;
            margin: 28px 0 16px;
        }
        
        .btn-primary {
            display: inline-block;
            background: linear-gradient(135deg, #48bb78 0%, #38a169 100%);
            color: #ffffff !important;
            text-decoration: none;
            padding: 14px 40px;
            border-radius: 50px;
            font-weight: 600;
            font-size: 16px;
            transition: all 0.3s ease;
            box-shadow: 0 6px 20px rgba(72, 187, 120, 0.3);
        }
        
        .btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 28px rgba(72, 187, 120, 0.4);
        }
        
        .btn-secondary {
            display: inline-block;
            color: #48bb78 !important;
            text-decoration: none;
            font-size: 14px;
            font-weight: 500;
            margin-top: 12px;
        }
        
        .btn-secondary:hover {
            text-decoration: underline;
        }
        
        .divider {
            border: 0;
            height: 1px;
            background: linear-gradient(90deg, transparent, #e2e8f0, transparent);
            margin: 28px 0 24px;
        }
        
        /* Footer */
        .footer {
            padding: 0 40px 32px;
            text-align: center;
        }
        
        .footer-text {
            color: #6b7a8f;
            font-size: 14px;
            line-height: 1.7;
        }
        
        .footer-text strong {
            color: #1a2332;
        }
        
        .social-links {
            margin: 16px 0 18px;
            display: flex;
            justify-content: center;
            gap: 16px;
            flex-wrap: wrap;
        }
        
        .social-link {
            display: inline-block;
            width: 38px;
            height: 38px;
            border-radius: 50%;
            background: #f1f4f9;
            color: #4a5568;
            text-decoration: none;
            text-align: center;
            line-height: 38px;
            font-size: 14px;
            transition: all 0.2s;
        }
        
        .social-link:hover {
            background: #48bb78;
            color: #ffffff;
        }
        
        .footer-divider {
            border: 0;
            height: 1px;
            background: #e8edf5;
            margin: 20px 0;
        }
        
        .footer-links {
            display: flex;
            justify-content: center;
            gap: 20px;
            flex-wrap: wrap;
            margin: 12px 0;
        }
        
        .footer-links a {
            color: #6b7a8f;
            text-decoration: none;
            font-size: 13px;
        }
        
        .footer-links a:hover {
            color: #48bb78;
            text-decoration: underline;
        }
        
        .copyright {
            color: #8a9aa8;
            font-size: 13px;
            margin-top: 12px;
        }
        
        .support-badge {
            display: inline-block;
            background: #ebf8ff;
            color: #2b6cb0;
            padding: 6px 16px;
            border-radius: 20px;
            font-size: 13px;
            margin-top: 8px;
        }
        
        /* Responsive */
        @media (max-width: 480px) {
            .email-body {
                padding: 24px 20px 20px;
            }
            
            .footer {
                padding: 0 20px 24px;
            }
            
            .email-header {
                padding: 24px 20px;
            }
            
            .greeting {
                font-size: 19px;
            }
            
            .order-summary {
                flex-direction: column;
                align-items: flex-start;
                gap: 8px;
                padding: 16px;
            }
            
            .details-grid {
                grid-template-columns: 1fr;
                gap: 12px;
            }
            
            .btn-primary {
                padding: 12px 28px;
                font-size: 15px;
                width: 100%;
            }
            
            .items-table {
                font-size: 14px;
            }
            
            .items-table thead th {
                font-size: 11px;
                padding: 8px 8px 8px 0;
            }
            
            .items-table tbody td {
                padding: 12px 8px 12px 0;
            }
            
            .product-image {
                width: 40px;
                height: 40px;
                font-size: 18px;
            }
            
            .product-name {
                font-size: 14px;
            }
            
            .footer-links {
                gap: 12px;
                font-size: 12px;
            }
            
            .totals-container {
                padding: 16px;
            }
        }
        
        @media (max-width: 400px) {
            .items-table thead th:nth-child(3),
            .items-table tbody td:nth-child(3) {
                display: none;
            }
        }
    </style>
</head>
<body>
    <!-- Email Wrapper -->
    <div class="email-wrapper">
        
        <!-- Header -->
        <div class="email-header">
            <a href="<%= storeUrl || '#' %>" class="logo">
                <span class="logo-icon">🛍️</span>
                Shop<span>Verse</span>
            </a>
            <div class="order-status <%= orderStatusClass || 'confirmed' %>">
                ✅ <%= orderStatus || 'Order Confirmed' %>
            </div>
        </div>
        
        <!-- Body -->
        <div class="email-body">
            
            <!-- Greeting -->
            <h1 class="greeting">
                Thank you, <span class="greeting-highlight"><%= customerName %></span>! 🎉
            </h1>
            
            <p style="color: #4a5568; font-size: 15px; margin-top: 4px;">
                Your order has been placed successfully and is being processed.
            </p>
            
            <!-- Order Summary -->
            <div class="order-summary">
                <div>
                    <div class="order-number">
                        Order #<strong><%= orderNumber %></strong>
                    </div>
                    <div class="order-date">
                        📅 <%= orderDate %>
                    </div>
                </div>
                <div class="order-total">
                    <span class="currency"><%= currencySymbol || '$' %></span><%= totalAmount %>
                </div>
            </div>
            
            <!-- Items Table -->
            <h3 style="font-size: 16px; font-weight: 600; color: #1a2332; margin-bottom: 12px;">
                Order Items
            </h3>
            
            <table class="items-table">
                <thead>
                    <tr>
                        <th style="width: 50%;">Product</th>
                        <th style="width: 15%; text-align: center;">Qty</th>
                        <th style="width: 17%; text-align: right;">Price</th>
                        <th style="width: 18%; text-align: right;">Total</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (items && items.length > 0) { %>
                        <% items.forEach(function(item) { %>
                        <tr>
                            <td>
                                <div class="product-info">
                                    <div class="product-image">
                                        <%= item.icon || '📦' %>
                                    </div>
                                    <div>
                                        <div class="product-name"><%= item.name %></div>
                                        <div class="product-sku">SKU: <%= item.sku || 'N/A' %></div>
                                    </div>
                                </div>
                            </td>
                            <td class="item-quantity"><%= item.quantity %></td>
                            <td class="item-price" style="text-align: right;">
                                <span class="currency"><%= currencySymbol || '$' %></span><%= item.price %>
                            </td>
                            <td class="item-total" style="text-align: right;">
                                <span class="currency"><%= currencySymbol || '$' %></span><%= item.total %>
                            </td>
                        </tr>
                        <% }); %>
                    <% } else { %>
                        <tr>
                            <td colspan="4" style="text-align: center; padding: 20px; color: #718096;">
                                No items found
                            </td>
                        </tr>
                    <% } %>
                </tbody>
            </table>
            
            <!-- Order Totals -->
            <div class="totals-container">
                <div class="totals-row subtotal">
                    <span class="label">Subtotal</span>
                    <span class="value"><span class="currency"><%= currencySymbol || '$' %></span><%= subtotal %></span>
                </div>
                
                <% if (discountAmount && discountAmount > 0) { %>
                <div class="totals-row discount">
                    <span class="label">Discount</span>
                    <span class="value">-<span class="currency"><%= currencySymbol || '$' %></span><%= discountAmount %></span>
                </div>
                <% } %>
                
                <div class="totals-row shipping">
                    <span class="label">Shipping</span>
                    <span class="value"><% if (shippingCost == 0) { %>Free<% } else { %><span class="currency"><%= currencySymbol || '$' %></span><%= shippingCost %><% } %></span>
                </div>
                
                <% if (taxAmount && taxAmount > 0) { %>
                <div class="totals-row" style="border-bottom: 1px solid #e2e8f0; padding-bottom: 10px; margin-bottom: 6px;">
                    <span class="label">Tax</span>
                    <span class="value"><span class="currency"><%= currencySymbol || '$' %></span><%= taxAmount %></span>
                </div>
                <% } %>
                
                <div class="totals-row grand-total">
                    <span class="label">Grand Total</span>
                    <span class="value"><span class="currency"><%= currencySymbol || '$' %></span><%= totalAmount %></span>
                </div>
            </div>
            
            <!-- Shipping & Payment Details -->
            <div class="details-grid">
                <div class="detail-box">
                    <h4>🚚 Shipping Address</h4>
                    <p>
                        <span class="address-line"><%= shippingAddress.name %></span>
                        <span class="address-line"><%= shippingAddress.street %></span>
                        <span class="address-line"><%= shippingAddress.city %>, <%= shippingAddress.state %> <%= shippingAddress.zip %></span>
                        <span class="address-line"><%= shippingAddress.country %></span>
                        <% if (shippingAddress.phone) { %>
                        <span class="address-line" style="margin-top: 6px; color: #718096; font-size: 13px;">
                            📞 <%= shippingAddress.phone %>
                        </span>
                        <% } %>
                    </p>
                </div>
                
                <div class="detail-box">
                    <h4>💳 Payment Method</h4>
                    <div class="payment-method">
                        <span class="card-icon"><%= paymentMethod.icon || '💳' %></span>
                        <div>
                            <div style="font-weight: 600; font-size: 14px;">
                                <%= paymentMethod.type || 'Credit Card' %>
                            </div>
                            <div style="font-size: 13px; color: #718096;">
                                <%= paymentMethod.details || '•••• 4242' %>
                            </div>
                        </div>
                    </div>
                    <p style="margin-top: 10px; font-size: 13px; color: #4a5568;">
                        Billed: <strong><span class="currency"><%= currencySymbol || '$' %></span><%= totalAmount %></strong>
                    </p>
                </div>
            </div>
            
            <!-- Additional Message -->
            <% if (specialInstructions) { %>
            <div style="background: #fffff0; border-left: 4px solid #ecc94b; padding: 12px 16px; border-radius: 6px; margin: 16px 0;">
                <p style="font-size: 14px; color: #744210; margin: 0;">
                    <strong>📝 Special Instructions:</strong> <%= specialInstructions %>
                </p>
            </div>
            <% } %>
            
            <p class="message-text">
                <strong>📦 What's next?</strong> You'll receive a shipping confirmation email with tracking information 
                once your order is dispatched. Estimated delivery: <strong><%= estimatedDelivery || '3-5 business days' %></strong>.
            </p>
            
            <p class="message-text" style="margin-top: 4px;">
                💬 Have questions about your order? Reply to this email or contact our support team.
            </p>
            
            <!-- Call to Action -->
            <div class="cta-container">
                <a href="<%= orderTrackingUrl || '#' %>" class="btn-primary">
                    📋 View Order Details
                </a>
                <br>
                <a href="<%= storeUrl || '#' %>" class="btn-secondary">
                    Continue Shopping →
                </a>
            </div>
            
            <hr class="divider">
            
            <!-- Support -->
            <div style="text-align: center;">
                <span class="support-badge">
                    💬 Need help? Contact us at <a href="mailto:support@shopverse.com" style="color: #2b6cb0; text-decoration: none; font-weight: 600;">support@shopverse.com</a>
                </span>
            </div>
            
        </div>
        
        <!-- Footer -->
        <div class="footer">
            
            <div class="social-links">
                <a href="#" class="social-link">📘</a>
                <a href="#" class="social-link">🐦</a>
                <a href="#" class="social-link">📺</a>
                <a href="#" class="social-link">💼</a>
                <a href="#" class="social-link">📸</a>
            </div>
            
            <div class="footer-text">
                <strong>ShopVerse</strong> — Your trusted online marketplace
            </div>
            
            <hr class="footer-divider">
            
            <div class="footer-links">
                <a href="#">Help Center</a>
                <a href="#">Track Order</a>
                <a href="#">Returns Policy</a>
                <a href="#">Privacy Policy</a>
                <a href="#">Unsubscribe</a>
            </div>
            
            <div class="copyright">
                &copy; <%= new Date().getFullYear() %> ShopVerse. All rights reserved.
                <br>
                <span style="font-size: 12px; color: #a0aec0;">
                    123 Commerce Blvd, Suite 200, San Francisco, CA 94105
                </span>
            </div>
            
        </div>
        
    </div>
</body>
</html>