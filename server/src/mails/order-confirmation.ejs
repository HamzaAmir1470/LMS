<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <title>Order Confirmation</title>
    <style>
        /* Reset styles for email clients */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
            background-color: #f4f7fb;
            line-height: 1.6;
            color: #1a2332;
            padding: 20px;
        }
        
        .email-wrapper {
            max-width: 550px;
            margin: 0 auto;
            background-color: #ffffff;
            border-radius: 16px;
            box-shadow: 0 8px 30px rgba(0, 0, 0, 0.05);
            overflow: hidden;
            border: 1px solid #e2e8f0;
        }
        
        /* Header */
        .email-header {
            background: linear-gradient(135deg, #2d3748 0%, #1a202c 100%);
            padding: 28px 40px;
            text-align: center;
        }
        
        .logo {
            display: inline-block;
            color: #ffffff;
            font-size: 26px;
            font-weight: 700;
            letter-spacing: -0.5px;
            text-decoration: none;
        }
        
        .logo span {
            font-weight: 300;
        }
        
        /* Content */
        .email-body {
            padding: 35px 40px;
        }
        
        .greeting {
            font-size: 22px;
            font-weight: 600;
            color: #1a2332;
            margin-bottom: 8px;
        }
        
        /* Details Summary Card */
        .order-card {
            background: #f7fafc;
            border-radius: 12px;
            padding: 20px 24px;
            margin: 24px 0;
            border: 1px solid #e2e8f0;
        }
        
        .card-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 10px 0;
            font-size: 15px;
            border-bottom: 1px solid #edf2f7;
        }
        
        .card-row:last-child {
            border-bottom: none;
            padding-top: 14px;
            font-weight: 700;
            font-size: 18px;
            color: #1a2332;
        }

        .label {
            color: #4a5568;
            font-weight: 500;
        }

        .value {
            color: #2d3748;
            text-align: right;
            font-weight: 600;
        }
        
        .divider {
            border: 0;
            height: 1px;
            background: linear-gradient(90deg, transparent, #e2e8f0, transparent);
            margin: 28px 0 24px;
        }
        
        /* Footer */
        .footer {
            padding: 0 40px 32px;
            text-align: center;
        }
        
        .footer-text {
            color: #6b7a8f;
            font-size: 14px;
        }
        
        .copyright {
            color: #a0aec0;
            font-size: 12px;
            margin-top: 12px;
        }
        
        /* Responsive tweaks */
        @media (max-width: 480px) {
            .email-body {
                padding: 24px 20px;
            }
            .footer {
                padding: 0 20px 24px;
            }
            .card-row {
                font-size: 14px;
            }
        }
    </style>
</head>
<body>
    <div class="email-wrapper">
        
        <div class="email-header">
            <div class="logo">Dev<span>Learn</span></div>
        </div>
        
        <div class="email-body">
            <h1 class="greeting">Thank you for your purchase! 🎉</h1>
            <p style="color: #4a5568; font-size: 15px;">
                Your course order has been processed successfully. Here are your purchase transaction details:
            </p>
            
            <div class="order-card">
                <div class="card-row">
                    <span class="label">Order ID</span>
                    <span class="value">#<%= order._id %></span>
                </div>
                <div class="card-row">
                    <span class="label">Course Name</span>
                    <span class="value"><%= order.name %></span>
                </div>
                <div class="card-row">
                    <span class="label">Purchase Date</span>
                    <span class="value">{" "}<%= order.date %></span>
                </div>
                <div class="card-row">
                    <span class="label">Total Price</span>
                    <span class="value">{" "}$<%= order.price %></span>
                </div>
            </div>
            
            <p style="color: #4a5568; font-size: 15px; text-align: center; margin-top: 16px;">
                If you have any questions or require assistance accessing your account, please contact our support team.
            </p>
            
            <hr class="divider">
        </div>
        
        <div class="footer">
            <div class="footer-text">
                <strong>DevLearn</strong> — Empowering Your Learning Journey
            </div>
            <div class="copyright">
                &copy; <%= new Date().getFullYear() %> DevLearn. All rights reserved.
            </div>
        </div>
        
    </div>
</body>
</html>