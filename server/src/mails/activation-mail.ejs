<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Activate Your Account</title>

  <style>
    *{
      margin:0;
      padding:0;
      box-sizing:border-box;
      font-family:Arial, Helvetica, sans-serif;
    }

    body{
      background:#f4f4f4;
      padding:40px 20px;
    }

    .container{
      max-width:600px;
      margin:auto;
      background:#fff;
      border-radius:12px;
      overflow:hidden;
      box-shadow:0 5px 20px rgba(0,0,0,.08);
    }

    .header{
      background:#2563eb;
      color:#fff;
      text-align:center;
      padding:30px;
    }

    .header h1{
      font-size:30px;
      margin-bottom:8px;
    }

    .content{
      padding:35px;
    }

    .content h2{
      color:#222;
      margin-bottom:15px;
    }

    .content p{
      color:#555;
      font-size:16px;
      line-height:1.7;
      margin-bottom:18px;
    }

    .code-box{
      text-align:center;
      margin:30px 0;
    }

    .code{
      display:inline-block;
      background:#2563eb;
      color:#fff;
      padding:15px 35px;
      border-radius:10px;
      font-size:34px;
      letter-spacing:8px;
      font-weight:bold;
    }

    .note{
      background:#f8f9fa;
      border-left:4px solid #2563eb;
      padding:15px;
      margin-top:25px;
      color:#555;
    }

    .footer{
      background:#f5f5f5;
      text-align:center;
      padding:20px;
      color:#777;
      font-size:14px;
    }

    @media(max-width:600px){
      .content{
        padding:25px;
      }

      .code{
        font-size:28px;
        letter-spacing:5px;
        padding:15px 20px;
      }
    }

  </style>
</head>

<body>

<div class="container">

  <div class="header">
    <h1>E-Learning</h1>
    <p>Account Verification</p>
  </div>

  <div class="content">

    <h2>Hello <%= user.name %> 👋</h2>

    <p>
      Thank you for registering on <strong>E-Learning</strong>.
      Please use the activation code below to verify your email address and activate your account.
    </p>

    <div class="code-box">
      <div class="code">
        <%= activationCode %>
      </div>
    </div>

    <p>
      This activation code will expire in
      <strong>5 minutes</strong>.
    </p>

    <div class="note">
      Enter this code on the verification page to activate your account.
      If you did not create this account, you can safely ignore this email.
    </div>

  </div>

  <div class="footer">
    © 2026 E-Learning. All Rights Reserved.
  </div>

</div>

</body>
</html>